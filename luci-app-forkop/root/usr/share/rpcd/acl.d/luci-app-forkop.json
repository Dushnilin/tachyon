{
  "luci-app-forkop": {
    "description": "Grant UCI and RPC access to LuCI app Forkop",
    "read": {
      "file": {
        "/etc/init.d/forkop": [
          "exec"
        ],
        "/var/run/forkop/section-cache/*": [
          "read"
        ],
        "/var/run/forkop/component-actions/*": [
          "read"
        ],
        "/var/run/forkop/ui-state/*": [
          "read"
        ],
        "/var/run/forkop/ui-state/service-actions/*": [
          "read"
        ],
        "/var/run/forkop/ui-state/latency-actions/*": [
          "read"
        ],
        "/usr/bin/forkop": [
          "exec"
        ]
      },
      "ubus": {
        "luci-rpc": [
          "getDHCPLeases",
          "getHostHints"
        ],
        "network.interface": [
          "dump"
        ],
        "service": [
          "list"
        ]
      },
      "uci": [
        "forkop"
      ]
    },
    "write": {
      "file": {
        "/var/run/forkop/ui-state/*": [
          "write"
        ],
        "/var/run/forkop/ui-state/service-actions/*": [
          "write"
        ],
        "/var/run/forkop/ui-state/latency-actions/*": [
          "write"
        ]
      },
      "uci": [
        "forkop"
      ]
    }
  }
}
