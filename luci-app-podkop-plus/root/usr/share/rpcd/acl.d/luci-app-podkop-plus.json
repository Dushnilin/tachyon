{
  "luci-app-podkop-plus": {
    "description": "Grant UCI and RPC access to LuCI app Podkop Plus",
    "read": {
      "file": {
        "/etc/init.d/podkop-plus": [
          "exec"
        ],
        "/var/run/podkop-plus/section-cache/*": [
          "read"
        ],
        "/var/run/podkop-plus/component-actions/*": [
          "read"
        ],
        "/usr/bin/podkop-plus": [
          "exec"
        ]
      },
      "ubus": {
        "luci-rpc": [
          "getDHCPLeases",
          "getHostHints"
        ],
        "network.interface": [
          "dump"
        ],
        "service": [
          "list"
        ]
      },
      "uci": [
        "podkop-plus"
      ]
    },
    "write": {
      "uci": [
        "podkop-plus"
      ]
    }
  }
}
